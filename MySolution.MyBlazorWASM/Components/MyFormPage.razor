@typeparam TModel where TModel : class
@inherits MyFormPageBase<TModel>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@(FormTitle ?? GetBaseFormTitle())</h2>
        <MyButton Text="Home" IconClass="bi bi-house" OnClick="GoToHome" />
    </div>

    <EditForm EditContext="EditContext" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        @foreach (var field in Fields)
        {
            <div class="mb-3">
                <label class="form-label fw-semibold">@field.Label</label>

                @if (field.Kind == InputKind.TextArea)
                {
                    <textarea class="form-control"
                              value="@GetDisplayValue(field)"
                              @oninput="args => SetValue(field, args.Value?.ToString())"></textarea>
                }
                else if (field.Kind == InputKind.Checkbox)
                {
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               checked="@GetBoolValue(field)"
                               @onchange="args => SetValue(field, args.Value)" />
                    </div>
                }
                else
                {
                    <input class="form-control"
                           type="@field.HtmlType"
                           value="@GetDisplayValue(field)"
                           @oninput="args => SetValue(field, args.Value?.ToString())" />
                }

                @foreach (var message in GetValidationMessages(field))
                {
                    <div class="validation-message" style="color: red; font-size: 0.85rem;">@message</div>
                }
            </div>
        }

        <button class="btn btn-primary" type="submit">@(SubmitButtonText ?? GetBaseSubmitButtonText())</button>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(SuccessMessage))
    {
        <div class="alert alert-success mt-3">@SuccessMessage</div>
    }
</div>

@code {
    [Parameter]
    public string? FormTitle { get; set; }

    [Parameter]
    public string? SubmitButtonText { get; set; }

    [Parameter]
    public EventCallback<TModel> OnValidModelSubmit { get; set; }

    protected override async Task OnValidModelSubmitAsync(TModel model)
    {
        if (OnValidModelSubmit.HasDelegate)
        {
            await OnValidModelSubmit.InvokeAsync(model);
            SuccessMessage = "Submitted successfully!";
        }
        else
        {
            SuccessMessage = "Form submitted!";
        }
    }
}
