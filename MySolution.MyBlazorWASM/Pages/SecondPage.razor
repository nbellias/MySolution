@page "/second"
@using MySolution.MyComponentsLib.Components

@inject NavigationManager Navigation

<PageTitle>Home</PageTitle>

<div class="d-flex flex-grow-1 flex-column align-items-center justify-content-center text-center py-5">
    <h1 class="display-1 mb-4 text-primary fw-bold">Blazor Magic</h1>
    
    <div class="mb-4">
        <MyButton Text="Take me Home" IconClass="bi bi-house-door" OnClick="GoToHome" />
    </div>

    <p class="lead mb-5 text-secondary">A spectacular button for a spectacular developer.</p>

    <MyButton Text="Experience the Ripple"
              IconClass="bi bi-stars"
              OnClick="@HandleClick" />

    @if (clicked)
    {
        <p class="mt-4 animate-bounce text-success fw-bold">Spectacular! 🎉</p>
    }
</div>

@code {
    private bool clicked = false;

    private void HandleClick()
    {
        clicked = true;
    }

    private void GoToHome()
    {
        // This is the programmatic way to change pages
        // instead of using an <a href="..."> link.
        Navigation.NavigateTo("/");
    }
}

<style>
    .animate-bounce {
        animation: bounce 0.5s infinite alternate;
    }
    @@keyframes bounce {
        from { transform: translateY(0); }
        to { transform: translateY(-10px); }
    }
</style>
